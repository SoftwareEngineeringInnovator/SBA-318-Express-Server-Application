<!-- Dashboard page for the Cybersecurity Incident Tracker -->
<!DOCTYPE html>
<html lang="en">
<head>
  
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- The page title comes from index.js using res.render() -->
  <title><%= pageTitle %></title>

  <!-- This connects our EJS page to the CSS file inside the public folder -->
  <link rel="stylesheet" href="../styles.css" />
</head>
<body>
  <!-- Header section for the top of the page -->
  <header class="site-header">
    <h1><%= pageTitle %></h1>
    <div class="header">
            <div class="logo">
                <span class="icon">⬡</span>
                <span class="text-logo">CYBER<strong>SHIELD</strong></span>
            </div>
    </div>
  </header>

  <!-- Main content area of the dashboard -->
  <main class="container">

    <!-- Form section to create a new incident -->
<section class="form-section">
  <h2>Create New Incident</h2>
  <p>Use this form to add a new cybersecurity incident to the tracker.</p>

  <!-- This form sends a POST request to our incidents API route -->
  <form action="/api/incidents" method="POST" class="incident-form">
    <div class="form-group">
      <label for="userId">Reported By User ID</label>
      <input type="number" id="userId" name="userId" min="1" required />
    </div>

    <div class="form-group">
      <label for="title">Incident Title</label>
      <input type="text" id="title" name="title" required />
    </div>

    <div class="form-group">
      <label for="category">Category</label>
      <input
        type="text"
        id="category"
        name="category"
        placeholder="Example: Authentication"
        required
      />
    </div>

    <div class="form-group">
      <label for="severity">Severity</label>
      <select id="severity" name="severity" required>
        <option value="">Select severity</option>
        <option value="Low">Low</option>
        <option value="Medium">Medium</option>
        <option value="High">High</option>
        <option value="Critical">Critical</option>
      </select>
    </div>

    <div class="form-group">
      <label for="status">Status</label>
      <select id="status" name="status" required>
        <option value="">Select status</option>
        <option value="Open">Open</option>
        <option value="Investigating">Investigating</option>
        <option value="Resolved">Resolved</option>
      </select>
    </div>

    <div class="form-group">
      <label for="description">Description</label>
      <textarea
        id="description"
        name="description"
        rows="4"
        required
      ></textarea>
    </div>

    <button type="submit">Add Incident</button>
  </form>
</section>

    <!-- Incidents Section -->
    <section class="dashboard-summary">
      <div class="summary-card">
        <h2>Total Incidents</h2>

        <!-- incidents.length counts how many incident objects are in the array -->
        <p><%= incidents.length %></p>
      </div>
    </section>

    <!-- Displays current incident reports -->
    <section class="incident-list">
      <h2>Current Incident Reports</h2>

      <!-- Loop that creates an incident item -->
      <% incidents.forEach((incident) => { %>

        <!-- Display incidents -->
        <article class="incident-card">

          <!-- Incidemt division sections -->
          <div class="incident-card-header">
            <h3><%= incident.title %></h3>
            <span class="severity severity-<%= incident.severity.toLowerCase() %>">
              <%= incident.severity %></span>
          </div>

          <!-- Details for each incident -->
          <p><strong>Category:</strong> <%= incident.category %></p>
          <p><strong>Status:</strong> <%= incident.status %></p>
          <p><strong>Description:</strong> <%= incident.description %></p>
          <p><strong>Reported By User ID:</strong> <%= incident.userId %></p>

          <!-- This link downloads the selected incident as a text report -->
           <a href="/api/incidents/<%= incident.id %>/download" class="download-button"> Download Report</a>
        </article>

      <% }) %>
    </section>
  </main>
</body>
</html>